qmake: FORCE
	@$(QMAKE) -o Makefile.test tikzit.pro CONFIG+=test

qmake_all: FORCE


all: Makefile.test UnitTests

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents src/data/tikzlexer.l $(DISTDIR)/
	$(COPY_FILE) --parents src/data/tikzparser.y $(DISTDIR)/
	$(COPY_FILE) --parents src/data/tikzparser.y $(DISTDIR)/
	$(COPY_FILE) --parents tikzit.qrc $(DISTDIR)/
	$(COPY_FILE) --parents /usr/lib/x86_64-linux-gnu/qt6/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents src/tikzit.h src/util.h src/gui/mainwindow.h src/gui/pathitem.h src/gui/toolpalette.h src/gui/tikzscene.h src/gui/propertypalette.h src/gui/tikzview.h src/gui/nodeitem.h src/gui/edgeitem.h src/gui/commands.h src/gui/undocommands.h src/gui/mainmenu.h src/gui/stylepalette.h src/gui/styleeditor.h src/gui/previewwindow.h src/gui/latexprocess.h src/gui/exportdialog.h src/gui/delimitedstringitemdelegate.h src/gui/preferencedialog.h src/gui/mgbUmlPalette.h src/gui/mgbFileManager.h src/gui/mgbPluginDialog.h src/data/path.h src/data/graph.h src/data/node.h src/data/edge.h src/data/graphelementdata.h src/data/graphelementproperty.h src/data/tikzparserdefs.h src/data/tikzdocument.h src/data/tikzassembler.h src/data/tikzstyles.h src/data/style.h src/data/stylelist.h src/data/pdfdocument.h src/data/delimitedstringvalidator.h src/data/mgbPluginManager.h src/test/testtest.h src/test/testparser.h src/test/testtikzoutput.h $(DISTDIR)/
	$(COPY_FILE) --parents src/tikzit.cpp src/util.cpp src/gui/mainwindow.cpp src/gui/pathitem.cpp src/gui/toolpalette.cpp src/gui/tikzscene.cpp src/gui/propertypalette.cpp src/gui/tikzview.cpp src/gui/nodeitem.cpp src/gui/edgeitem.cpp src/gui/commands.cpp src/gui/undocommands.cpp src/gui/mainmenu.cpp src/gui/stylepalette.cpp src/gui/styleeditor.cpp src/gui/previewwindow.cpp src/gui/latexprocess.cpp src/gui/exportdialog.cpp src/gui/delimitedstringitemdelegate.cpp src/gui/preferencedialog.cpp src/gui/mgbUmlPalette.cpp src/gui/mgbFileManager.cpp src/gui/mgbPluginDialog.cpp src/data/path.cpp src/data/graph.cpp src/data/node.cpp src/data/edge.cpp src/data/graphelementdata.cpp src/data/graphelementproperty.cpp src/data/tikzdocument.cpp src/data/tikzassembler.cpp src/data/tikzstyles.cpp src/data/style.cpp src/data/stylelist.cpp src/data/pdfdocument.cpp src/data/delimitedstringvalidator.cpp src/data/mgbPluginManager.cpp src/test/testmain.cpp src/test/testtest.cpp src/test/testparser.cpp src/test/testtikzoutput.cpp $(DISTDIR)/
	$(COPY_FILE) --parents src/gui/mainwindow.ui src/gui/propertypalette.ui src/gui/mainmenu.ui src/gui/stylepalette.ui src/gui/styleeditor.ui src/gui/previewwindow.ui src/gui/exportdialog.ui src/gui/preferencedialog.ui $(DISTDIR)/


clean: compiler_clean 
	-$(DEL_FILE) $(OBJECTS)
	-$(DEL_FILE) *~ core *.core


distclean: clean 
	-$(DEL_FILE) $(TARGET) 
	-$(DEL_FILE) /root/mgb-uml/target_wrapper.sh .qmake.stash
	-$(DEL_FILE) Makefile.test


####### Sub-libraries

check: first
	/root/mgb-uml/target_wrapper.sh $(TESTRUNNER) ./$(QMAKE_TARGET) $(TESTARGS)

mocclean: compiler_moc_header_clean compiler_moc_objc_header_clean compiler_moc_source_clean

mocables: compiler_moc_header_make_all compiler_moc_objc_header_make_all compiler_moc_source_make_all

benchmark: first

compiler_flex_make_all: src/data/tikzlexer.lexer.cpp
compiler_flex_clean:
	-$(DEL_FILE) src/data/tikzlexer.lexer.cpp
src/data/tikzlexer.lexer.cpp: src/data/tikzlexer.l
	flex --header-file=src/data/tikzlexer.h -o src/data/tikzlexer.lexer.cpp src/data/tikzlexer.l

compiler_bison_make_all: src/data/tikzparser.parser.cpp
compiler_bison_clean:
	-$(DEL_FILE) src/data/tikzparser.parser.cpp
src/data/tikzparser.parser.cpp: src/data/tikzparser.y
	bison -d -o src/data/tikzparser.parser.cpp src/data/tikzparser.y

compiler_bison_header_make_all: src/data/tikzparser.parser.hpp
compiler_bison_header_clean:
	-$(DEL_FILE) src/data/tikzparser.parser.hpp
src/data/tikzparser.parser.hpp: src/data/tikzparser.y
	bison -d -o src/data/tikzparser.parser.cpp src/data/tikzparser.y

compiler_rcc_make_all: qrc_tikzit.cpp
compiler_rcc_clean:
	-$(DEL_FILE) qrc_tikzit.cpp
qrc_tikzit.cpp: tikzit.qrc \
		/usr/lib/qt6/libexec/rcc \
		images/loader@2x.gif \
		images/loader.gif \
		images/dialog-error.svg \
		images/refresh.svg \
		images/text-x-generic_with_pencil.svg \
		images/tikzit-tool-node.svg \
		images/tikzit-tool-select.svg \
		images/tikzit.png \
		images/document-open.svg \
		images/tikzit-tool-edge.svg \
		images/document-new.svg \
		images/dialog-accept.svg \
		qt.conf \
		tex/sample/tikzit.sty
	/usr/lib/qt6/libexec/rcc -name tikzit tikzit.qrc -o qrc_tikzit.cpp

compiler_moc_predefs_make_all: moc_predefs.h
compiler_moc_predefs_clean:
	-$(DEL_FILE) moc_predefs.h
moc_predefs.h: /usr/lib/x86_64-linux-gnu/qt6/mkspecs/features/data/dummy.cpp
	ccache g++ -pipe -O2 -Wall -Wextra -fPIC -dM -E -o moc_predefs.h /usr/lib/x86_64-linux-gnu/qt6/mkspecs/features/data/dummy.cpp

compiler_moc_header_make_all: moc_tikzit.cpp moc_mainwindow.cpp moc_toolpalette.cpp moc_tikzscene.cpp moc_propertypalette.cpp moc_tikzview.cpp moc_mainmenu.cpp moc_stylepalette.cpp moc_styleeditor.cpp moc_previewwindow.cpp moc_latexprocess.cpp moc_exportdialog.cpp moc_delimitedstringitemdelegate.cpp moc_preferencedialog.cpp moc_mgbUmlPalette.cpp moc_mgbFileManager.cpp moc_mgbPluginDialog.cpp moc_path.cpp moc_graph.cpp moc_node.cpp moc_edge.cpp moc_graphelementdata.cpp moc_tikzdocument.cpp moc_tikzassembler.cpp moc_tikzstyles.cpp moc_style.cpp moc_stylelist.cpp moc_pdfdocument.cpp moc_delimitedstringvalidator.cpp moc_mgbPluginManager.cpp moc_testtest.cpp moc_testparser.cpp moc_testtikzoutput.cpp
compiler_moc_header_clean:
	-$(DEL_FILE) moc_tikzit.cpp moc_mainwindow.cpp moc_toolpalette.cpp moc_tikzscene.cpp moc_propertypalette.cpp moc_tikzview.cpp moc_mainmenu.cpp moc_stylepalette.cpp moc_styleeditor.cpp moc_previewwindow.cpp moc_latexprocess.cpp moc_exportdialog.cpp moc_delimitedstringitemdelegate.cpp moc_preferencedialog.cpp moc_mgbUmlPalette.cpp moc_mgbFileManager.cpp moc_mgbPluginDialog.cpp moc_path.cpp moc_graph.cpp moc_node.cpp moc_edge.cpp moc_graphelementdata.cpp moc_tikzdocument.cpp moc_tikzassembler.cpp moc_tikzstyles.cpp moc_style.cpp moc_stylelist.cpp moc_pdfdocument.cpp moc_delimitedstringvalidator.cpp moc_mgbPluginManager.cpp moc_testtest.cpp moc_testparser.cpp moc_testtikzoutput.cpp
moc_tikzit.cpp: src/tikzit.h \
		src/gui/mainwindow.h \
		src/gui/tikzscene.h \
		src/data/graph.h \
		src/data/node.h \
		src/data/graphelementdata.h \
		src/data/graphelementproperty.h \
		src/mgb_api.h \
		src/data/style.h \
		src/data/edge.h \
		src/data/path.h \
		src/gui/nodeitem.h \
		src/gui/edgeitem.h \
		src/gui/pathitem.h \
		src/data/tikzdocument.h \
		src/gui/toolpalette.h \
		src/gui/stylepalette.h \
		src/gui/tikzview.h \
		src/gui/mainmenu.h \
		ui_mainmenu.h \
		src/gui/styleeditor.h \
		src/data/tikzstyles.h \
		src/data/stylelist.h \
		src/gui/propertypalette.h \
		src/gui/latexprocess.h \
		src/gui/previewwindow.h \
		src/data/pdfdocument.h \
