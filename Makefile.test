####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/usr/local/bin || mkdir -p $(INSTALL_ROOT)/usr/local/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/usr/local/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/usr/local/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/usr/local/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/local/bin/ 


install_share: first FORCE
	@test -d $(INSTALL_ROOT)/usr/local/share || mkdir -p $(INSTALL_ROOT)/usr/local/share
	$(QINSTALL) /root/mgb-uml/share/applications $(INSTALL_ROOT)/usr/local/share/applications
	$(QINSTALL) /root/mgb-uml/share/icons $(INSTALL_ROOT)/usr/local/share/icons
	$(QINSTALL) /root/mgb-uml/share/man $(INSTALL_ROOT)/usr/local/share/man
	$(QINSTALL) /root/mgb-uml/share/mime $(INSTALL_ROOT)/usr/local/share/mime

uninstall_share: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/share/mime
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/share/man
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/share/icons
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/local/share/applications
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/local/share/ 


install: install_target install_share  FORCE

uninstall: uninstall_target uninstall_share  FORCE

FORCE:

.SUFFIXES:

